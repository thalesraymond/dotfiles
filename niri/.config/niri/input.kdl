input {
    disable-power-key-handling
    keyboard {
        xkb {
            layout "us"
            variant "intl"
        }

        numlock
    }

    mouse {
        accel-speed 0.1
        accel-profile "flat"
    }
    
    focus-follows-mouse max-scroll-amount="20%"
}

cursor {
    xcursor-theme "Bibata-Modern-Classic"
    xcursor-size 24
}